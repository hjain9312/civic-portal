<!-- Login Page Container -->
<div class="login-wrapper">
  <div class="login-container">
    <h1>Welcome Back</h1>
    <div class="login-options">
      <%= link_to new_normal_user_session_path, class: 'btn btn-user' do %>
        <span class="icon" aria-hidden="true">👤</span>
        <span class="btn-text">User Login</span>
      <% end %>
      <%= link_to new_authority_session_path, class: 'btn btn-admin' do %>
        <span class="icon" aria-hidden="true">🔒</span>
        <span class="btn-text">Administrator Login</span>
      <% end %>
    </div>
    <div class="login-footer">
      <p>Access your account securely</p>
    </div>
  </div>
</div>

<style>
  /* Reset some default styles to prevent scroll issues */
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow-x: hidden;
  }

  /* Ensure the wrapper takes up the full viewport height */
  .login-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: #f4f7fc;
    padding: 20px;
    box-sizing: border-box;
  }

  .login-container {
    background-color: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12), 0 10px 20px rgba(0, 0, 0, 0.05);
    max-width: 420px;
    width: 100%;
    padding: 3.5rem 2.5rem;
    text-align: center;
    animation: fadeIn 0.6s ease;
    border: 1px solid rgba(234, 234, 234, 0.8);
    opacity: 0;
    position: relative;
    overflow: hidden;
  }

  .login-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 8px;
    background: linear-gradient(90deg, #4361ee, #3a0ca3);
  }

  .login-container.fade-in {
    opacity: 1;
  }

  .login-container h1 {
    color: #2d3748;
    margin-bottom: 2.5rem;
    font-weight: 800;
    font-size: 2.2rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    display: inline-block;
  }
  
  .login-container h1::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #4361ee, #3a0ca3);
    border-radius: 2px;
  }

  .login-options {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    margin-bottom: 2rem;
  }
  
  .login-footer {
    margin-top: 2.5rem;
    color: #718096;
    font-size: 0.95rem;
    font-weight: 500;
  }
  
  .btn-text {
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 1.1rem 1rem;
    border-radius: 12px;
    border: none;
    font-size: 1.2rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    text-decoration: none;
    color: #fff;
    width: 100%;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.1);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s ease;
    z-index: -1;
  }

  .btn:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .btn-user {
    background: linear-gradient(135deg, #4361ee 0%, #3a56d4 100%);
    box-shadow: 0 6px 15px rgba(67, 97, 238, 0.25), 0 2px 5px rgba(67, 97, 238, 0.15);
  }

  .btn-user:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(67, 97, 238, 0.35), 0 4px 10px rgba(67, 97, 238, 0.2);
  }

  .btn-admin {
    background: linear-gradient(135deg, #4c1bb3 0%, #3a0ca3 100%);
    box-shadow: 0 6px 15px rgba(58, 12, 163, 0.25), 0 2px 5px rgba(58, 12, 163, 0.15);
    margin-top: 0.5rem;
  }

  .btn-admin:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(58, 12, 163, 0.35), 0 4px 10px rgba(58, 12, 163, 0.2);
  }

  .icon {
    font-size: 1.5rem;
    line-height: 1;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.1));
    transition: transform 0.3s ease;
  }
  
  .btn:hover .icon {
    transform: scale(1.15);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .login-container {
      padding: 2.5rem 1.8rem;
      margin: 0 15px;
    }
    
    .btn {
      font-size: 1.1rem;
      padding: 1rem;
    }
    
    .login-container h1 {
      font-size: 1.8rem;
      margin-bottom: 2rem;
    }
    
    .login-container h1::after {
      width: 60px;
      height: 3px;
    }
    
    .icon {
      font-size: 1.3rem;
    }
    
    .login-footer {
      margin-top: 2rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Fix for possible scroll issues by ensuring proper height
    document.documentElement.style.height = '100%';
    document.body.style.height = '100%';
    
    // Apply fade-in animation
    const loginContainer = document.querySelector('.login-container');
    
    // Use setTimeout to ensure the initial state is fully applied before transition
    setTimeout(function() {
      loginContainer.classList.add('fade-in');
    }, 10);
  });
</script>