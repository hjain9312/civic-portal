<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CivicComplaints</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Stylesheet -->
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body>
    <nav class="navbar">
      <div class="container">
        <div class="logo">
          <%= link_to root_path, class: 'logo-link' do %>
            <i class="fas fa-city"></i> Civic Complaints
          <% end %>
        </div>
        <div class="nav-links">
          <% if user_signed_in? %>
            <%= button_to destroy_user_session_path, method: :delete, class: 'btn-logout' do %>
              <i class="fas fa-sign-out-alt"></i> Logout
            <% end %>
          <% else %>
            <%= link_to new_user_session_path, class: 'nav-link' do %>
              <i class="fas fa-sign-in-alt"></i> Login
            <% end %>
            <%= link_to new_user_registration_path, class: 'nav-link' do %>
              <i class="fas fa-user-plus"></i> Sign Up
            <% end %>
          <% end %>
        </div>
      </div>
    </nav>
    
    <div class="container main-content">
      <% if notice %>
        <div class="notice">
          <i class="fas fa-check-circle"></i> <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert">
          <i class="fas fa-exclamation-circle"></i> <%= alert %>
        </div>
      <% end %>
      
      <%= yield %>
    </div>
  </body>
</html>

