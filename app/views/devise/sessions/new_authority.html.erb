<h2>Login as Authority</h2>

<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<%= form_with url: login_authority_path, method: :post, scope: :user, local: true do |form| %>
  <div class="form-group">
    <%= form.label :email %>
    <%= form.email_field :email, autofocus: true, placeholder: 'Authority Email', class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :password %>
    <%= form.password_field :password, placeholder: 'Password', class: 'form-control' %>
  </div>

  <div class="actions">
    <%= form.submit 'Login as Authority', class: 'btn btn-primary' %>
  </div>
<% end %>