<!-- new_normal_user.html.erb (for login as civilian) -->
<div class="login-signup-wrapper">
  <div class="login-signup-box">
    <h2><i class="fas fa-user"></i> Login as Citizen</h2>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: login_normal_user_path, scope: :user, local: true do |f| %>
      <div class="form-group">
        <div class="input-icon-wrapper">
          <i class="fas fa-envelope input-icon"></i>
          <%= f.email_field :email, autofocus: true, placeholder: 'Email Address', class: 'form-control' %>
        </div>
      </div>

      <div class="form-group">
        <div class="input-icon-wrapper">
          <i class="fas fa-lock input-icon"></i>
          <%= f.password_field :password, placeholder: 'Password', class: 'form-control' %>
        </div>
      </div>

      <div class="actions">
        <%= f.submit 'Login', class: 'btn-primary btn-block' %>
      </div>
    <% end %>

    <div class="auth-links">
      <p>Don't have an account? <%= link_to "Sign up", new_user_registration_path %></p>
      <p><%= link_to "Forgot your password?", new_password_path(resource_name) if defined?(resource_name) %></p>
    </div>
  </div>
</div>