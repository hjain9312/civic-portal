<div class="content-wrapper">
  <div class="profile-container">
    <div class="profile-header">
      <div class="profile-avatar">
        <i class="fas fa-user-circle"></i>
      </div>
      <h1 class="profile-heading">Your Profile</h1>
    </div>
    
    <div class="profile-card">
      <div class="profile-info">
        <div class="info-item">
          <div class="info-label">
            <i class="fas fa-user"></i>
            <span>Name</span>
          </div>
          <div class="info-value"><%= @profile.name %></div>
        </div>
        
        <div class="info-item">
          <div class="info-label">
            <i class="fas fa-envelope"></i>
            <span>Email</span>
          </div>
          <div class="info-value"><%= @profile.email %></div>
        </div>
        
        <div class="info-item">
          <div class="info-label">
            <i class="fas fa-id-badge"></i>
            <span>Role</span>
          </div>
          <div class="info-value">
            <span class="role-badge"><%= @profile.role.titleize %></span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="profile-actions">
      <%= link_to edit_normal_user_profile_path, class: "btn btn-primary" do %>
        <i class="fas fa-user-edit"></i> Edit Profile
      <% end %>
      
      <%= link_to normal_user_dashboard_path, class: "btn btn-secondary" do %>
        <i class="fas fa-tachometer-alt"></i> Back to Dashboard
      <% end %>
    </div>
  </div>
</div>

<!-- Add this to your CSS file for the profile styles -->
