<div class="content-wrapper">
  <div class="page-header">
    <h1 class="complaints-heading">
      <i class="fas fa-clipboard-list"></i> Your Complaints
    </h1>
    <%= link_to new_complaint_path, class: "btn btn-primary header-action" do %>
      <i class="fas fa-plus"></i> New Complaint
    <% end %>
  </div>

  <% if @complaints.any? %>
    <div class="complaints-table-wrapper">
      <table class="complaints-table" id="complaintsTable">
        <thead>
          <tr>
            <th>Type</th>
            <th>Title</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @complaints.each do |complaint| %>
            <tr class="complaint-row" data-status="<%= complaint.status.downcase.gsub(' ', '_') %>">
              <td class="complaint-type">
                <div class="type-badge">
                  <%= complaint.complaint_type.name %>
                </div>
              </td>
              <td class="complaint-title">
                <div class="type-badge">
                  <%= complaint.title %>
                </div>
              </td>
              <td class="complaint-status">
                <span class="status-badge status-<%= complaint.status.downcase.gsub(' ', '-') %>">
                  <%= complaint.status %>
                </span>
              </td>
              <td class="complaint-actions">
                <div class="action-buttons">
                  <%= link_to complaint_path(complaint), class: "btn-icon", title: "View Details" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  
                  <%= link_to edit_complaint_path(complaint), class: "btn-icon", title: "Edit Complaint" do %>
                    <i class="fas fa-edit"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <div class="pagination-container">
      <!-- Pagination would go here if implemented -->
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-icon">
        <i class="fas fa-clipboard"></i>
      </div>
      <h3>No Complaints Yet</h3>
      <p class="no-complaints-text">You haven't submitted any complaints yet.</p>
      <%= link_to new_complaint_path, class: "btn btn-primary" do %>
        <i class="fas fa-plus"></i> Submit Your First Complaint
      <% end %>
    </div>
  <% end %>
</div>

<!-- Helper method to get icon based on complaint type - add to a helper file -->
<% 
  def get_complaint_icon(type)
    icon = case type.downcase
      when /pothole/, /road/
        "fa-road"
      when /gutter/, /drain/
        "fa-water"
      when /sewage/, /sewer/
        "fa-toilet"
      when /garbage/, /waste/
        "fa-trash"
      when /street.*light/
        "fa-lightbulb"
      when /water/
        "fa-faucet"
      else
        "fa-exclamation-circle"
    end
    
    "<i class='fas #{icon}'></i>".html_safe
  end
%>

<!-- Add this to your CSS file for the complaints list styles -->
<style>
