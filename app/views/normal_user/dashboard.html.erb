<div class="dashboard-container">
  <div class="dashboard-header">
    <h1 class="dashboard-welcome">
      <i class="fas fa-user-circle user-avatar"></i>
      Welcome, <%= current_user.email %>
    </h1>
  </div>

  <div class="dashboard-links">
    <%= link_to new_complaint_path, class: 'dashboard-tab' do %>
      <i class="fas fa-file-alt"></i>
      <span>Create Complaint</span> 
    <% end %>
    
    <%= link_to normal_user_complaints_path, class: 'dashboard-tab' do %>
      <i class="fas fa-list"></i>
      <span>My Complaints</span>
    <% end %>
    
    <%= link_to edit_normal_user_profile_path, class: 'dashboard-tab' do %>
      <i class="fas fa-user-edit"></i>
      <span>Edit Profile</span>
    <% end %>
    
    <%= link_to normal_user_profile_path, class: 'dashboard-tab' do %>
      <i class="fas fa-id-card"></i>
      <span>Your Profile</span>
    <% end %>
  </div>
  
  <div class="content-wrapper">
    <div class="dashboard-summary">
      <div class="summary-card">
        <div class="summary-icon">
          <i class="fas fa-file-alt"></i>
        </div>
        <div class="summary-info">
          <h3>Total Complaints</h3>
          <p class="summary-count"><%= @complaints_count || 0 %></p>
        </div>
      </div>
      
      <div class="summary-card">
        <div class="summary-icon">
          <i class="fas fa-spinner"></i>
        </div>
        <div class="summary-info">
          <h3>Pending</h3>
          <p class="summary-count"><%= @pending_count || 0 %></p>
        </div>
      </div>
      
      <div class="summary-card">
        <div class="summary-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <div class="summary-info">
          <h3>Resolved</h3>
          <p class="summary-count"><%= @resolved_count || 0 %></p>
        </div>
      </div>
    </div>
    
    <div class="recent-activity">
      <h2><i class="fas fa-history"></i> Recent Activity</h2>
      <% if @recent_complaints&.any? %>
        <div class="complaints-table-wrapper">
          <table class="complaints-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_complaints.each do |complaint| %>
                <tr>
                  <td>#<%= complaint.id %></td>
                  <td><%= complaint.title %></td>
                  <td>
                    <span class="status-badge status-<%= complaint.status.downcase %>">
                      <%= complaint.status.capitalize %>
                    </span>
                  </td>
                  <td><%= complaint.created_at.strftime("%d %b, %Y") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="no-complaints-text">No recent complaints to display.</p>
      <% end %>
    </div>
  </div>
</div>